{
  "name": "ketto-gym-assistant",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"tsc -p tsconfig.electron.json --watch\" \"set ELECTRON_RUN_AS_NODE=& set NODE_ENV=development& wait-on tcp:5173 dist-electron/main.js && electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "start": "set ELECTRON_RUN_AS_NODE=& set NODE_ENV=production& electron ."
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "10.4.19",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
